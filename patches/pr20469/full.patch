+@router.post("/{id:uuid}/create_flow_run/bulk")
+async def bulk_create_flow_runs_from_deployment(
+    flow_runs: List[schemas.actions.DeploymentFlowRunCreate] = Body(
+        ..., description="List of flow run configurations to create"
